# Apache (.htaccess) - configuración simulada para el reto
# Nota: en entornos tipo GitHub Pages este archivo no se aplica; aquí es parte del CTF.

# flag-part: 1s_f4k3}

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Evita servir archivos “ocultos” (defensa típica)
  RewriteRule "(^|/)\." - [F]
</IfModule>

<Files ".htaccess">
  Require all denied
</Files>
